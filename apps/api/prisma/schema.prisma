generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleCode {
  ADMIN_TU
  KESISWAAN
  BK
  GURU_MAPEL
  ORANG_TUA
}

enum StaffPositionCode {
  GURU_MAPEL
  BK
  TU
  KESISWAAN
  WALI_KELAS
}

enum GenderType {
  L
  P
}

enum WeekdayEnum {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum AttendanceStatus {
  HADIR
  ALFA
  IZIN
  SAKIT
  DISPENSASI
  BOLOS
}

enum AttendanceSource {
  BASE_CHECK
  CROSS_CHECK
  BK_PERMISSION
  DISPENSATION
  SYSTEM_DERIVED
  TAP_IN
  TAP_OUT
  MANUAL_ADMIN
}

enum PermissionState {
  ACTIVE
  CANCELLED
}

enum BkPermissionKind {
  IZIN
  SAKIT
}

enum DispensationState {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum CalendarDayType {
  SCHOOL_DAY
  HOLIDAY
  EXAM_DAY
  SPECIAL_SCHEDULE
}

enum TapType {
  IN
  OUT
}

enum TapDeviceType {
  RFID
  BARCODE
  QR
  NFC
}

enum TapProcessingStatus {
  RECEIVED
  MATCHED
  REJECTED
  PROCESSED
}

model User {
  id               String                   @id @default(uuid()) @db.Uuid
  username         String                   @unique @db.VarChar(50)
  passwordHash     String                   @map("password_hash")
  refreshTokenHash String?                  @map("refresh_token_hash")
  fullName         String                   @map("full_name") @db.VarChar(150)
  isActive         Boolean                  @default(true) @map("is_active")
  lastLoginAt      DateTime?                @map("last_login_at") @db.Timestamptz
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz
  roles            UserRole[]
  staff            Staff?
  parent           Parent?
  bkPermissions    BkLeavePermission[]      @relation("BkPermissionCreatedByUser")
  dispensations    Dispensation[]           @relation("DispensationCreatedByUser")
  attendanceMarks  AttendancePeriodStatus[] @relation("AttendanceMarkedByUser")
  attendanceAudits AttendanceAuditLog[]     @relation("AttendanceAuditChangedByUser")

  @@map("users")
}

model Role {
  code        RoleCode   @id
  name        String     @unique @db.VarChar(50)
  description String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleCode   RoleCode @map("role_code")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleCode], references: [code], onDelete: Restrict)

  @@id([userId, roleCode])
  @@index([roleCode])
  @@map("user_roles")
}

model Staff {
  id              String                    @id @default(uuid()) @db.Uuid
  userId          String?                   @unique @map("user_id") @db.Uuid
  fullName        String                    @map("full_name") @db.VarChar(150)
  employeeNumber  String                    @unique @map("employee_number") @db.VarChar(50)
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime                  @updatedAt @map("updated_at") @db.Timestamptz
  user            User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  positions       StaffPositionAssignment[]
  homeroomClasses Class[]                   @relation("ClassHomeroomStaff")
  schedules       ClassSchedule[]           @relation("ClassScheduleTeacher")
  approvedBk      BkLeavePermission[]       @relation("BkPermissionApprovedByStaff")
  approvedDisp    Dispensation[]            @relation("DispensationApprovedByStaff")

  @@map("staffs")
}

model StaffPosition {
  code        StaffPositionCode         @id
  name        String                    @unique @db.VarChar(50)
  description String?
  createdAt   DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  assignments StaffPositionAssignment[]

  @@map("staff_positions")
}

model StaffPositionAssignment {
  staffId      String            @map("staff_id") @db.Uuid
  positionCode StaffPositionCode @map("position_code")
  assignedAt   DateTime          @default(now()) @map("assigned_at") @db.Timestamptz
  isPrimary    Boolean           @default(false) @map("is_primary")
  staff        Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  position     StaffPosition     @relation(fields: [positionCode], references: [code], onDelete: Restrict)

  @@id([staffId, positionCode])
  @@index([positionCode])
  @@map("staff_position_assignments")
}

model Parent {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String?             @unique @map("user_id") @db.Uuid
  fullName  String              @map("full_name") @db.VarChar(150)
  phone     String?             @db.VarChar(30)
  email     String?             @db.VarChar(150)
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  students  ParentStudentLink[]

  @@map("parents")
}

model Batch {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(100)
  entryYear   Int       @unique @map("entry_year")
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  classes     Class[]
  students    Student[]

  @@map("batches")
}

model AcademicYear {
  id           String              @id @default(uuid()) @db.Uuid
  name         String              @unique @db.VarChar(20)
  startDate    DateTime            @map("start_date") @db.Date
  endDate      DateTime            @map("end_date") @db.Date
  isActive     Boolean             @default(false) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  classes      Class[]
  schedules    ClassSchedule[]
  calendarDays SchoolCalendarDay[]

  @@map("academic_years")
}

model Class {
  id                String                      @id @default(uuid()) @db.Uuid
  batchId           String                      @map("batch_id") @db.Uuid
  academicYearId    String                      @map("academic_year_id") @db.Uuid
  name              String                      @db.VarChar(100)
  gradeLevel        Int                         @map("grade_level")
  major             String?                     @db.VarChar(50)
  parallelCode      String?                     @map("parallel_code") @db.VarChar(10)
  homeroomStaffId   String?                     @map("homeroom_staff_id") @db.Uuid
  isActive          Boolean                     @default(true) @map("is_active")
  createdAt         DateTime                    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime                    @updatedAt @map("updated_at") @db.Timestamptz
  batch             Batch                       @relation(fields: [batchId], references: [id], onDelete: Restrict)
  academicYear      AcademicYear                @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  homeroomStaff     Staff?                      @relation("ClassHomeroomStaff", fields: [homeroomStaffId], references: [id], onDelete: SetNull)
  enrollments       StudentClassEnrollment[]
  schedules         ClassSchedule[]
  bkPermissions     BkLeavePermission[]
  dispensationLinks DispensationStudent[]
  attendance        AttendancePeriodStatus[]
  dailyOverrides    DailyLessonPeriodOverride[]

  @@unique([academicYearId, name])
  @@map("classes")
}

model Student {
  id            String                   @id @default(uuid()) @db.Uuid
  batchId       String                   @map("batch_id") @db.Uuid
  nis           String                   @unique @db.VarChar(50)
  fullName      String                   @map("full_name") @db.VarChar(150)
  gender        GenderType?
  birthDate     DateTime?                @map("birth_date") @db.Date
  barcodeValue  String?                  @unique @map("barcode_value") @db.VarChar(100)
  rfidUid       String?                  @unique @map("rfid_uid") @db.VarChar(100)
  isActive      Boolean                  @default(true) @map("is_active")
  createdAt     DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime                 @updatedAt @map("updated_at") @db.Timestamptz
  batch         Batch                    @relation(fields: [batchId], references: [id], onDelete: Restrict)
  enrollments   StudentClassEnrollment[]
  parents       ParentStudentLink[]
  bkPermissions BkLeavePermission[]
  dispensations DispensationStudent[]
  attendance    AttendancePeriodStatus[]
  tapEvents     TapEvent[]

  @@map("students")
}

model StudentClassEnrollment {
  id        String    @id @default(uuid()) @db.Uuid
  studentId String    @map("student_id") @db.Uuid
  classId   String    @map("class_id") @db.Uuid
  startDate DateTime  @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class     Class     @relation(fields: [classId], references: [id], onDelete: Restrict)

  @@unique([studentId, classId, startDate])
  @@map("student_class_enrollments")
}

model ParentStudentLink {
  id           String   @id @default(uuid()) @db.Uuid
  parentId     String   @map("parent_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  relationship String   @db.VarChar(30)
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  parent       Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_student_links")
}

model Subject {
  id        String          @id @default(uuid()) @db.Uuid
  code      String          @unique @db.VarChar(30)
  name      String          @db.VarChar(150)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  schedules ClassSchedule[]

  @@map("subjects")
}

model LessonPeriod {
  periodNo             Int                         @id @map("period_no")
  label                String                      @db.VarChar(30)
  startTime            DateTime                    @map("start_time") @db.Time(0)
  endTime              DateTime                    @map("end_time") @db.Time(0)
  isActive             Boolean                     @default(true) @map("is_active")
  schedules            ClassSchedule[]
  bkPermissionStarts   BkLeavePermission[]         @relation("BkPermissionStartPeriod")
  bkPermissionEnds     BkLeavePermission[]         @relation("BkPermissionEndPeriod")
  bkReturnExpectations BkLeavePermission[]         @relation("BkPermissionExpectedReturnPeriod")
  dispensationStarts   Dispensation[]              @relation("DispensationStartPeriod")
  dispensationEnds     Dispensation[]              @relation("DispensationEndPeriod")
  dispReturnPeriods    Dispensation[]              @relation("DispensationExpectedReturnPeriod")
  attendance           AttendancePeriodStatus[]
  dailyOverrides       DailyLessonPeriodOverride[]

  @@map("lesson_periods")
}

model SchoolCalendarDay {
  calendarDate   DateTime                    @id @map("calendar_date") @db.Date
  academicYearId String                      @map("academic_year_id") @db.Uuid
  dayType        CalendarDayType             @default(SCHOOL_DAY) @map("day_type")
  title          String                      @db.VarChar(150)
  description    String?
  isSchoolDay    Boolean                     @default(true) @map("is_school_day")
  createdAt      DateTime                    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime                    @updatedAt @map("updated_at") @db.Timestamptz
  academicYear   AcademicYear                @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  overrides      DailyLessonPeriodOverride[]

  @@map("school_calendar_days")
}

model DailyLessonPeriodOverride {
  id             String            @id @default(uuid()) @db.Uuid
  calendarDate   DateTime          @map("calendar_date") @db.Date
  lessonPeriodNo Int               @map("lesson_period_no")
  classId        String?           @map("class_id") @db.Uuid
  label          String            @db.VarChar(30)
  startTime      DateTime          @map("start_time") @db.Time(0)
  endTime        DateTime          @map("end_time") @db.Time(0)
  isActive       Boolean           @default(true) @map("is_active")
  reason         String?
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  calendarDay    SchoolCalendarDay @relation(fields: [calendarDate], references: [calendarDate], onDelete: Cascade)
  lessonPeriod   LessonPeriod      @relation(fields: [lessonPeriodNo], references: [periodNo], onDelete: Restrict)
  class          Class?            @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("daily_lesson_period_overrides")
}

model ClassSchedule {
  id             String                   @id @default(uuid()) @db.Uuid
  academicYearId String                   @map("academic_year_id") @db.Uuid
  classId        String                   @map("class_id") @db.Uuid
  subjectId      String                   @map("subject_id") @db.Uuid
  teacherStaffId String                   @map("teacher_staff_id") @db.Uuid
  weekday        WeekdayEnum
  lessonPeriodNo Int                      @map("lesson_period_no")
  roomName       String?                  @map("room_name") @db.VarChar(50)
  isActive       Boolean                  @default(true) @map("is_active")
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz
  academicYear   AcademicYear             @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class          Class                    @relation(fields: [classId], references: [id], onDelete: Restrict)
  subject        Subject                  @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teacher        Staff                    @relation("ClassScheduleTeacher", fields: [teacherStaffId], references: [id], onDelete: Restrict)
  lessonPeriod   LessonPeriod             @relation(fields: [lessonPeriodNo], references: [periodNo], onDelete: Restrict)
  attendance     AttendancePeriodStatus[]

  @@unique([classId, weekday, lessonPeriodNo])
  @@unique([teacherStaffId, academicYearId, weekday, lessonPeriodNo])
  @@map("class_schedules")
}

model BkLeavePermission {
  id                     String                   @id @default(uuid()) @db.Uuid
  studentId              String                   @map("student_id") @db.Uuid
  classId                String                   @map("class_id") @db.Uuid
  attendanceDate         DateTime                 @map("attendance_date") @db.Date
  permissionKind         BkPermissionKind         @map("permission_kind")
  startPeriodNo          Int                      @map("start_period_no")
  endPeriodNo            Int                      @map("end_period_no")
  returnRequired         Boolean                  @default(false) @map("return_required")
  expectedReturnPeriodNo Int?                     @map("expected_return_period_no")
  reason                 String
  letterNumber           String?                  @map("letter_number") @db.VarChar(50)
  status                 PermissionState          @default(ACTIVE)
  createdByUserId        String?                  @map("created_by_user_id") @db.Uuid
  approvedByStaffId      String                   @map("approved_by_staff_id") @db.Uuid
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime                 @updatedAt @map("updated_at") @db.Timestamptz
  student                Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class                  Class                    @relation(fields: [classId], references: [id], onDelete: Restrict)
  createdByUser          User?                    @relation("BkPermissionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByStaff        Staff                    @relation("BkPermissionApprovedByStaff", fields: [approvedByStaffId], references: [id], onDelete: Restrict)
  startPeriod            LessonPeriod             @relation("BkPermissionStartPeriod", fields: [startPeriodNo], references: [periodNo], onDelete: Restrict)
  endPeriod              LessonPeriod             @relation("BkPermissionEndPeriod", fields: [endPeriodNo], references: [periodNo], onDelete: Restrict)
  expectedReturnPeriod   LessonPeriod?            @relation("BkPermissionExpectedReturnPeriod", fields: [expectedReturnPeriodNo], references: [periodNo], onDelete: Restrict)
  attendanceStatuses     AttendancePeriodStatus[]

  @@index([studentId, attendanceDate, startPeriodNo, endPeriodNo, status])
  @@map("bk_leave_permissions")
}

model Dispensation {
  id                     String                   @id @default(uuid()) @db.Uuid
  title                  String                   @db.VarChar(150)
  description            String?
  attendanceDate         DateTime                 @map("attendance_date") @db.Date
  startPeriodNo          Int                      @map("start_period_no")
  endPeriodNo            Int                      @map("end_period_no")
  returnRequired         Boolean                  @default(false) @map("return_required")
  expectedReturnPeriodNo Int?                     @map("expected_return_period_no")
  letterNumber           String?                  @map("letter_number") @db.VarChar(50)
  status                 DispensationState        @default(DRAFT)
  createdByUserId        String?                  @map("created_by_user_id") @db.Uuid
  approvedByStaffId      String?                  @map("approved_by_staff_id") @db.Uuid
  publishedAt            DateTime?                @map("published_at") @db.Timestamptz
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime                 @updatedAt @map("updated_at") @db.Timestamptz
  createdByUser          User?                    @relation("DispensationCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByStaff        Staff?                   @relation("DispensationApprovedByStaff", fields: [approvedByStaffId], references: [id], onDelete: SetNull)
  startPeriod            LessonPeriod             @relation("DispensationStartPeriod", fields: [startPeriodNo], references: [periodNo], onDelete: Restrict)
  endPeriod              LessonPeriod             @relation("DispensationEndPeriod", fields: [endPeriodNo], references: [periodNo], onDelete: Restrict)
  expectedReturnPeriod   LessonPeriod?            @relation("DispensationExpectedReturnPeriod", fields: [expectedReturnPeriodNo], references: [periodNo], onDelete: Restrict)
  students               DispensationStudent[]
  attendanceStatuses     AttendancePeriodStatus[]

  @@map("dispensations")
}

model DispensationStudent {
  dispensationId String       @map("dispensation_id") @db.Uuid
  studentId      String       @map("student_id") @db.Uuid
  classId        String       @map("class_id") @db.Uuid
  dispensation   Dispensation @relation(fields: [dispensationId], references: [id], onDelete: Cascade)
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class          Class        @relation(fields: [classId], references: [id], onDelete: Restrict)

  @@id([dispensationId, studentId])
  @@index([studentId, classId])
  @@map("dispensation_students")
}

model AttendancePeriodStatus {
  id                         String                   @id @default(uuid()) @db.Uuid
  attendanceDate             DateTime                 @map("attendance_date") @db.Date
  studentId                  String                   @map("student_id") @db.Uuid
  classId                    String                   @map("class_id") @db.Uuid
  lessonPeriodNo             Int                      @map("lesson_period_no")
  scheduleId                 String?                  @map("schedule_id") @db.Uuid
  status                     AttendanceStatus
  source                     AttendanceSource
  note                       String?
  markedByUserId             String?                  @map("marked_by_user_id") @db.Uuid
  previousAttendanceStatusId String?                  @map("previous_attendance_status_id") @db.Uuid
  bkPermissionId             String?                  @map("bk_permission_id") @db.Uuid
  dispensationId             String?                  @map("dispensation_id") @db.Uuid
  verifiedAt                 DateTime?                @map("verified_at") @db.Timestamptz
  createdAt                  DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                  DateTime                 @updatedAt @map("updated_at") @db.Timestamptz
  student                    Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class                      Class                    @relation(fields: [classId], references: [id], onDelete: Restrict)
  lessonPeriod               LessonPeriod             @relation(fields: [lessonPeriodNo], references: [periodNo], onDelete: Restrict)
  schedule                   ClassSchedule?           @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  markedByUser               User?                    @relation("AttendanceMarkedByUser", fields: [markedByUserId], references: [id], onDelete: SetNull)
  previousAttendanceStatus   AttendancePeriodStatus?  @relation("AttendancePreviousStatus", fields: [previousAttendanceStatusId], references: [id], onDelete: SetNull)
  nextAttendanceStatuses     AttendancePeriodStatus[] @relation("AttendancePreviousStatus")
  bkPermission               BkLeavePermission?       @relation(fields: [bkPermissionId], references: [id], onDelete: SetNull)
  dispensation               Dispensation?            @relation(fields: [dispensationId], references: [id], onDelete: SetNull)
  auditLogs                  AttendanceAuditLog[]
  tapEvents                  TapEvent[]               @relation("LinkedAttendanceTapEvents")

  @@unique([attendanceDate, studentId, lessonPeriodNo])
  @@index([studentId, attendanceDate, lessonPeriodNo])
  @@index([classId, attendanceDate, lessonPeriodNo])
  @@map("attendance_period_statuses")
}

model AttendanceAuditLog {
  id                       String                 @id @default(uuid()) @db.Uuid
  attendancePeriodStatusId String                 @map("attendance_period_status_id") @db.Uuid
  previousStatus           AttendanceStatus?      @map("previous_status")
  newStatus                AttendanceStatus       @map("new_status")
  changeSource             AttendanceSource       @map("change_source")
  changedByUserId          String?                @map("changed_by_user_id") @db.Uuid
  reason                   String?
  metadata                 Json                   @default("{}")
  createdAt                DateTime               @default(now()) @map("created_at") @db.Timestamptz
  attendancePeriodStatus   AttendancePeriodStatus @relation(fields: [attendancePeriodStatusId], references: [id], onDelete: Cascade)
  changedByUser            User?                  @relation("AttendanceAuditChangedByUser", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@map("attendance_audit_logs")
}

model TapDevice {
  id                  String        @id @default(uuid()) @db.Uuid
  deviceCode          String        @unique @map("device_code") @db.VarChar(50)
  deviceName          String        @map("device_name") @db.VarChar(100)
  deviceType          TapDeviceType @map("device_type")
  locationDescription String?       @map("location_description") @db.VarChar(150)
  isActive            Boolean       @default(true) @map("is_active")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  tapEvents           TapEvent[]

  @@map("tap_devices")
}

model TapEvent {
  id                       String                  @id @default(uuid()) @db.Uuid
  studentId                String?                 @map("student_id") @db.Uuid
  nisInput                 String                  @map("nis_input") @db.VarChar(50)
  tapType                  TapType                 @map("tap_type")
  tappedAt                 DateTime                @map("tapped_at") @db.Timestamptz
  deviceId                 String?                 @map("device_id") @db.Uuid
  externalEventId          String?                 @map("external_event_id") @db.VarChar(100)
  deviceSequence           BigInt?                 @map("device_sequence")
  rawPayload               Json                    @default("{}") @map("raw_payload")
  processingStatus         TapProcessingStatus     @default(RECEIVED) @map("processing_status")
  linkedAttendanceStatusId String?                 @map("linked_attendance_status_id") @db.Uuid
  createdAt                DateTime                @default(now()) @map("created_at") @db.Timestamptz
  student                  Student?                @relation(fields: [studentId], references: [id], onDelete: SetNull)
  device                   TapDevice?              @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  linkedAttendanceStatus   AttendancePeriodStatus? @relation("LinkedAttendanceTapEvents", fields: [linkedAttendanceStatusId], references: [id], onDelete: SetNull)

  @@index([studentId, tappedAt])
  @@index([nisInput, tappedAt])
  @@map("tap_events")
}
