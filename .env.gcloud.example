PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/attendance_db?schema=public
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Use this value when accessing the VM through SSH tunnel:
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
CORS_ORIGIN=http://localhost:3001

# If you expose the app through a VM public IP or domain, use one of these instead:
# NEXT_PUBLIC_API_BASE_URL=http://YOUR_VM_EXTERNAL_IP:3000/api/v1
# CORS_ORIGIN=http://YOUR_VM_EXTERNAL_IP:3001
# NEXT_PUBLIC_API_BASE_URL=https://your-domain.example.com/api/v1
# CORS_ORIGIN=https://your-domain.example.com
