              "raw": "{\n  \"classId\": \"{{classId}}\",\n  \"scheduleId\": \"{{scheduleId}}\",\n  \"attendanceDate\": \"2026-04-20\",\n  \"lessonPeriodNo\": 1,\n  \"records\": [\n    {\n      \"studentId\": \"{{studentId}}\",\n      \"status\": \"HADIR\",\n      \"note\": \"Base check manual\"\n    }\n  ]\n}"
